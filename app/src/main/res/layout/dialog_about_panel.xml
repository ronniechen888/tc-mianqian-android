<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/cyber_panel"
    android:orientation="vertical"
    android:padding="18dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:letterSpacing="0.08"
        android:text="ABOUT / NOTICE"
        android:textColor="@color/cyber_cyan"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="TC支付监控端说明"
        android:textColor="@color/cyber_text"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="功能说明、运行建议与使用边界"
        android:textColor="@color/cyber_muted"
        android:textSize="12sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="14dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/cyber_footer_line" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:background="@drawable/cyber_terminal"
        android:fadeScrollbars="false"
        android:padding="0dp"
        android:scrollbars="vertical">

        <TextView
            android:id="@+id/about_dialog_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:lineSpacingExtra="3dp"
            android:padding="12dp"
            android:textColor="@color/cyber_text"
            android:textSize="13sp" />
    </ScrollView>
</LinearLayout>
